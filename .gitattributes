# Auto-normalize line endings for all files
* text=auto

# Force Unix line endings for shell scripts
*.sh text eol=lf
Dockerfile* text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
