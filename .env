# ==========================================
# Backend (TypeScript/Node.js)
# ==========================================

NODE_ENV=production
SERVER_PORT=6005
LOG_LEVEL=info

# ==========================================
# IBKR Gateway (Primary Broker)
# ==========================================

IB_USERNAME=alharthy2026
IB_PASSWORD=Nasra_2026
IB_GATEWAY_HOST=ib-gateway
IB_GATEWAY_PORT=4002

# ==========================================
# Database
# ==========================================

DB_PASSWORD=strongpassword123

# ==========================================
# Python Service (Docker)
# ==========================================

PYTHON_SERVICE_URL=http://python-service:6105
PYTHON_SERVICE_TIMEOUT=30000
PYTHON_LOG_LEVEL=INFO

# ==========================================
# Risk Management
# ==========================================

# Position sizing
MAX_POSITION_RISK_PERCENT=0.01
MAX_POSITION_SIZE_PERCENT=0.15
KELLY_CEILING=0.25

# Portfolio management
MAX_PORTFOLIO_HEAT=0.07
MAX_POSITIONS=8
MAX_PER_STRATEGY=3
MAX_SECTOR_PERCENT=0.25

# Stop-loss settings
MAX_STOP_PERCENT=0.05
ATR_STOP_MULTIPLIER=2.5
CHANDELIER_MULTIPLIER=3.0
USE_FIXED_PERCENT_STOP=false

# Drawdown circuit breakers
DRAWDOWN_YELLOW_PERCENT=0.05
DRAWDOWN_ORANGE_PERCENT=0.10
DRAWDOWN_RED_PERCENT=0.15
DRAWDOWN_HALT_PERCENT=0.20

# Take-profit targets
TAKE_PROFIT_RR_RATIO=2.0
PARTIAL_EXIT_PCT=0.33
TRAIL_REMAINING=true

# ==========================================
# Strategy Parameters
# ==========================================

# Trend/Breakout Strategy (Strategy 1)
STRATEGY_1_ENABLED=true
STRATEGY_1_ATR_PERIOD=14
STRATEGY_1_ATR_MULTIPLIER=2.5
STRATEGY_1_MA_FAST=50
STRATEGY_1_MA_SLOW=200
STRATEGY_1_RSI_PERIOD=14
STRATEGY_1_RSI_MIN=40
STRATEGY_1_RSI_MAX=70
STRATEGY_1_RVOL_THRESHOLD=1.5
STRATEGY_1_MIN_CONFIDENCE=60

# Pullback/Reversion Strategy (Strategy 2)
STRATEGY_2_ENABLED=true
STRATEGY_2_MA_PERIOD=50
STRATEGY_2_FIB_LEVEL_MIN=0.382
STRATEGY_2_FIB_LEVEL_MAX=0.618
STRATEGY_2_RSI_PERIOD=14
STRATEGY_2_RSI_THRESHOLD=50
STRATEGY_2_VOLUME_THRESHOLD=0.8
STRATEGY_2_MIN_CONFIDENCE=60

# Hybrid Strategy (Strategy 3)
STRATEGY_3_ENABLED=true
STRATEGY_3_TREND_WEIGHT=0.25
STRATEGY_3_MOMENTUM_WEIGHT=0.20
STRATEGY_3_VOLUME_WEIGHT=0.15
STRATEGY_3_PATTERN_WEIGHT=0.15
STRATEGY_3_REGIME_WEIGHT=0.15
STRATEGY_3_VOLATILITY_WEIGHT=0.10
STRATEGY_3_THRESHOLD=65
STRATEGY_3_MIN_CONFIDENCE=60

# ==========================================
# Technical Indicators
# ==========================================

# Moving Averages
MA_PERIODS=50,100,200

# RSI
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# MACD
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# Bollinger Bands
BB_PERIOD=20
BB_STD_DEV=2.0

# ATR
ATR_PERIOD=14

# Volume
VOLUME_MA_PERIOD=20
OBV_PERIOD=20

# Fibonacci
FIB_MIN_SWING_PERCENT=0.05
FIB_ATR_FILTER=1.5

# ==========================================
# Market & Trading Parameters
# ==========================================

# Trading timeframes
PRIMARY_TIMEFRAME=1D
SECONDARY_TIMEFRAMES=4H,1W

# Trading hours
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=30
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=0
TRADING_TIMEZONE=America/New_York

# Slippage & commissions
SLIPPAGE_BPS=5
COMMISSION_PER_SHARE=0.0

# Data
LOOKBACK_PERIOD_DAYS=252
MIN_DATA_POINTS=100

# Massive API (Market Data Provider)
MASSIVE_API_KEY=5R4SHomkZSrZ3vzwkKcYDkNznmoXMtpe

# ==========================================
# Shariah Compliance
# ==========================================

SHARIAH_ENABLED=true
SHARIAH_EQUITY_DEBT_LIMIT=0.30
SHARIAH_HARAM_INCOME_LIMIT=0.05
ENFORCE_LONG_ONLY=true
ENFORCE_NO_LEVERAGE=true
ENFORCE_NO_DERIVATIVES=true

# Asset universe (comma-separated)
SHARIAH_EQUITIES=AAPL,MSFT,GOOGL,AMZN,NVDA
SHARIAH_ETFS=GLD,SLV,SGOL,IAU,BAR
SHARIAH_CRYPTOCURRENCIES=BTC,ETH

# ==========================================
# Notification & Monitoring
# ==========================================

ENABLE_TRADE_ALERTS=true
ALERT_ON_SIGNAL=true
ALERT_ON_RISK_LIMIT=true
ALERT_ON_ERROR=true

# Email (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# Slack (optional)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#trading-alerts

# ==========================================
# Logging & Monitoring
# ==========================================

LOG_LEVEL=info
LOG_FILE=logs/trading.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# Health checks
HEALTH_CHECK_INTERVAL_MS=10000
HEALTH_CHECK_TIMEOUT_MS=5000

# ==========================================
# Development
# ==========================================

DEBUG=false
MOCK_ORDERS=false
MOCK_DATA=false
